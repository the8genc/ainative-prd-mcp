# AINative PRD Generator MCP Configuration
#
# If no credentials are set, the server auto-provisions a free ZeroDB instance.
# To keep your PRDs permanently, sign up at https://ainative.studio
# or run: npx zerodb-cli init

# ===========================================
# Authentication (choose one)
# ===========================================

# Option 1: API key (recommended)
# ZERODB_API_KEY=ak_your_key_here
# ZERODB_PROJECT_ID=your-project-id

# Option 2: Username/password
# ZERODB_USERNAME=your@email.com
# ZERODB_PASSWORD=your-password

# ===========================================
# Connection
# ===========================================

# API endpoint (default: https://api.ainative.studio)
# ZERODB_API_URL=https://api.ainative.studio

# AINATIVE_* are accepted as aliases for ZERODB_* (used by the Railway deploy)
# AINATIVE_API_KEY=sk_or_ak_your_key
# AINATIVE_API_URL=https://api.ainative.studio

# ===========================================
# Transport
# ===========================================

# Transport: "stdio" (default) or "http" (Streamable HTTP).
# Auto-selects "http" when PORT is set (e.g. on Railway).
# MCP_TRANSPORT=http
# PORT=8080

# ===========================================
# Skills (Agent Skills library)
# ===========================================

# GitHub repo that holds the skills (source of truth). ZeroDB caches them.
# SKILLS_REPO=the8genc/ai-8gent-skills
# SKILLS_BRANCH=main
# Optional token to raise GitHub API rate limits
# SKILLS_GITHUB_TOKEN=ghp_your_token

# ===========================================
# Auth + portal (enabled only when DATABASE_URL is set)
# ===========================================
#
# When DATABASE_URL is set, POST /mcp requires an approved credential
# (OAuth token or personal access token) and the portal is served at /access.
# Without DATABASE_URL the server runs unauthenticated (local/stdio parity).

# Postgres (Railway provides this as a reference variable)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Public origin the server is reached at (OAuth issuer + resource base)
# PUBLIC_BASE_URL=https://mcp.8genc.com

# Secret used to sign session + access tokens (REQUIRED in production; long random)
# JWT_SECRET=change-me-to-a-long-random-string  (REQUIRED in production)
# SESSION_COOKIE_SECURE=true
# SESSION_TTL_SECONDS=14400            # portal session lifetime (default 4h)
# MCP_RATE_LIMIT_PER_MIN=600           # per-credential /mcp requests per minute
# PG_REJECT_UNAUTHORIZED=true          # enforce strict DB TLS cert validation (default off for managed DBs)

# Initial admin seed (only used on first migrate if no admin exists)
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_PASSWORD=admin

# Social login (PR3) — register apps with callback https://mcp.8genc.com/auth/{google,github}/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email delivery: dev (logs links to stdout) | resend | smtp
# EMAIL_PROVIDER=dev
# EMAIL_FROM=no-reply@8genc.com
# RESEND_API_KEY=
# SMTP_URL=smtp://user:pass@host:587
