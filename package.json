{
  "name": "8genc-mcp-server",
  "version": "2.0.0",
  "description": "8genC MCP Server — AINative platform discovery (services, API catalog, stack suggestions) plus a GitHub-backed Agent Skills library exposed as MCP tools and prompts",
  "type": "module",
  "main": "index.js",
  "bin": {
    "8genc-mcp-server": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "migrate": "node src/db/migrate.js",
    "build": "npm --prefix web ci && npm --prefix web run build",
    "build:web": "npm --prefix web run build",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 node --test tests/*.test.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-server-hosting",
    "model-context-protocol",
    "model-context-protocol-server",
    "agent-skills",
    "skills",
    "platform-discovery",
    "ainative",
    "zerodb",
    "zeromemory",
    "ai-agents",
    "agentic-ai",
    "ai-tool-calling",
    "agent-memory",
    "persistent-memory",
    "claude",
    "claude-code",
    "claude-desktop",
    "windsurf",
    "cursor",
    "production-ready"
  ],
  "author": {
    "name": "AINative Studio",
    "email": "toby@rely.ventures",
    "url": "https://ainative.studio"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/the8genc/8genc-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/the8genc/8genc-mcp-server/issues"
  },
  "homepage": "https://github.com/the8genc/8genc-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "arctic": "^2.3.4",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "c8": "^8.0.0"
  },
  "files": [
    "index.js",
    "src/**/*.js",
    "src/knowledge/*.json",
    "README.md",
    "LICENSE",
    ".env.example",
    ".claude/",
    ".cody/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
