# System / agency .env — used to build & run the orchestrator.
# Copy to .env (gitignored). Holds the SDK auth + the agency's SHARED tool keys (the keys for
# tools whose policy is "shared" in orchestrator.mcp.json). client-owned tool keys do NOT go
# here — each client uploads their own .env (see client.env.example).

# --- Claude Agent SDK auth (required to run) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: route through a cloud provider instead of the Anthropic API
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# --- Agency shared tool keys (policy: shared) ---
DATAFORSEO_USERNAME=agency-user
DATAFORSEO_PASSWORD=agency-pass
CODA_API_KEY=agency-coda-key
FAL_API_KEY=agency-fal-key
