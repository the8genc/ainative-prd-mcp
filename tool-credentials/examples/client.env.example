# CLIENT .env — a single client's own API keys, for "client-owned" tools (and optional overrides
# of shared tools). This is the file a client UPLOADS in the dashboard to do client-specific work.
# Run with:  --client-env path/to/this.env   (the run is scoped to this client; their keys only
# ever touch their own resources). Gitignored; written to a secret store, never committed.

# Square (client's own POS account)
SQUARE_ACCESS_TOKEN=client-square-token
SQUARE_ENV=production
SQUARE_LOCATION_ID=client-location-id

# Framer (client's own site)
FRAMER_API_KEY=client-framer-key
FRAMER_PROJECT_URL=https://framer.com/projects/Client--xxxx

# Others as the project needs:
# SQUARESPACE_API_KEY=...
# CANVA_ACCESS_TOKEN=...
# FIGMA_TOKEN=...
# WORDPRESS_URL=...  WORDPRESS_USER=...  WORDPRESS_APP_PASSWORD=...
# GHOST_API_URL=...  GHOST_ADMIN_API_KEY=...

# Optional: override a shared tool with the client's own account
# DATAFORSEO_USERNAME=client-user
# DATAFORSEO_PASSWORD=client-pass
